# Burnless local release/runtime environment.
# Copy only if needed; preferred local secret storage is ~/.config/burnless/*.env
# Never commit real values.

# Runtime provider keys
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=

# PyPI release. Keep the real file at ~/.config/burnless/pypi.env with chmod 600.
TWINE_USERNAME=__token__
TWINE_PASSWORD=pypi-...

# Optional service envs used by ops/site scripts.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
